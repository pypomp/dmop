#!/bin/bash
#SBATCH --job-name="pypomp dacca test (train)"
#SBATCH --partition=gpu-rtx6000
#SBATCH --gpus=rtx_pro_6000_blackwell:1
#SBATCH --cpus-per-gpu=1
#SBATCH --mem=10GB
#SBATCH --output=dmop_results/logs/slurm-%j.out
#SBATCH --time=0-0:30:00
#SBATCH --mail-type=fail,end

# Note: account and mail-user can be set via environment variables (SBATCH_ACCOUNT and SBATCH_MAIL_USER)
# e.g., by sourcing the .slurm_vars file in the project root.

. ../../.venv/bin/activate

export RUN_LEVEL=4

python -u dmop_search.py